rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isBootstrapAdmin() {
      return request.auth.token.email == 'amphysicist.bl@gmail.com' && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        isBootstrapAdmin() ||
        get(/databases/$(database)/documents/user_configs/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // 2. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. User Configs Collection
    match /user_configs/{userId} {
      function isOwner(uid) {
        return isSignedIn() && request.auth.uid == uid;
      }

      function isValidUserConfig(data) {
        return data.keys().hasAll(['email', 'isAdmin']) &&
               data.email is string && data.email.size() <= 256 &&
               data.isAdmin is bool &&
               (!('geminiApiKey' in data) || (data.geminiApiKey is string && data.geminiApiKey.size() <= 200));
      }

      // Read access: Owner or Admin
      allow get: if isOwner(userId) || isAdmin();
      
      // List access: Only Admin
      allow list: if isAdmin();

      // Create: Users can create their own doc but cannot make themselves admin
      allow create: if isOwner(userId) && 
                      isValidUserConfig(incoming()) && 
                      (incoming().isAdmin == false || isBootstrapAdmin());

      // Update: Owner can update their doc
      allow update: if isOwner(userId) && 
                      isValidUserConfig(incoming()) && (
                        // Admins can change everything
                        isAdmin() || 
                        // Regular users cannot change their isAdmin status
                        (incoming().isAdmin == existing().isAdmin)
                      );
      
      // Delete: Only Admin or Owner
      allow delete: if isOwner(userId) || isAdmin();
    }
  }
}
