{
  "rules": {
    "user_configs": {
      // Allows the Admin to list all user configurations
      ".read": "auth != null && (auth.token.email === 'amphysicist.bl@gmail.com' || root.child('user_configs').child(auth.uid).child('isAdmin').val() === true)",
      "$uid": {
        // Users can read their own config. Owners or Admins can write.
        ".read": "auth != null && (auth.uid === $uid || auth.token.email === 'amphysicist.bl@gmail.com' || root.child('user_configs').child(auth.uid).child('isAdmin').val() === true)",
        ".write": "auth != null && (auth.uid === $uid || auth.token.email === 'amphysicist.bl@gmail.com' || root.child('user_configs').child(auth.uid).child('isAdmin').val() === true)"
      },
      ".indexOn": ["email"]
    },
    "lessonPlans": {
      ".read": "true",
      "$planId": {
        ".write": "auth != null"
      }
    },
    "archivedPlans": {
      ".read": "auth != null",
      "$planId": {
        ".write": "auth != null && (!data.exists() || data.child('authorId').val() === auth.uid)"
      },
      ".indexOn": ["authorId"]
    }
  }
}
